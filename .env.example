# Copy to .env and adjust for your machine.

# Path to a PQC-capable OpenSSL binary. OpenSSL >= 3.5 has native ML-KEM /
# ML-DSA / SLH-DSA support (the study used 3.6.3); leave as "openssl" to use
# whatever is on PATH. Older 3.x builds require the OQS provider instead.
PQR_OPENSSL_BIN=openssl

# Legacy only: path to the oqs-provider module for pre-3.5 OpenSSL builds.
PQR_OQS_PROVIDER_PATH=

# Default concurrency for probing (threads).
PQR_MAX_WORKERS=20
